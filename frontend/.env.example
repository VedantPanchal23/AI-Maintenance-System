# ══════════════════════════════════════════════════════════════
# Frontend Environment Configuration — PRODUCTION
# Copy to .env.local and fill in ALL values before deploying.
# ══════════════════════════════════════════════════════════════

# Backend API URL (REQUIRED — no trailing slash)
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# WebSocket URL (REQUIRED — no trailing slash)
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com
