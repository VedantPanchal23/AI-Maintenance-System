# ============================================================
# AI Predictive Maintenance System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
# ============================================================

# ---------- Application ----------
APP_NAME=predictive-maintenance
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- Database ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=predictive_maintenance
POSTGRES_USER=pmuser
POSTGRES_PASSWORD=change_me_in_production
# DATABASE_URL is computed from above — shown for reference only, not loaded from env
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL is computed from above — shown for reference only, not loaded from env
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ---------- JWT Authentication ----------
JWT_SECRET_KEY=replace-with-256-bit-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- ML Configuration ----------
ML_MODEL_DIR=./ml_models/saved_models
ML_DEFAULT_MODEL=xgboost
ML_PREDICTION_THRESHOLD=0.7
ML_RETRAIN_INTERVAL_HOURS=24

# ---------- Alert Configuration ----------
ALERT_HIGH_RISK_THRESHOLD=0.8
ALERT_MEDIUM_RISK_THRESHOLD=0.5
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@predictive-maintenance.local

# ---------- Simulation ----------
SIMULATION_ENABLED=false
SIMULATION_INTERVAL_SECONDS=5
SIMULATION_EQUIPMENT_COUNT=10

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
