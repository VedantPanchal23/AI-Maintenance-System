# ══════════════════════════════════════════════════════════════
# Backend Environment Configuration — PRODUCTION
# Copy to .env and fill in ALL values before deploying.
# ══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database (REQUIRED) ─────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=predictive_maintenance
POSTGRES_USER=pmuser
POSTGRES_PASSWORD=          # REQUIRED — set a strong password

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── JWT (REQUIRED) ──────────────────────────────────────────
JWT_SECRET_KEY=             # REQUIRED — min 32 chars, use: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML Models ────────────────────────────────────────────────
ML_MODEL_DIR=./ml_models/saved_models
ML_DEFAULT_MODEL=xgboost
ML_PREDICTION_THRESHOLD=0.7
ML_RETRAIN_INTERVAL_HOURS=24

# ── Alerts & Email ───────────────────────────────────────────
ALERT_HIGH_RISK_THRESHOLD=0.8
ALERT_MEDIUM_RISK_THRESHOLD=0.5
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=

# ── Simulation (set true only for testing, false for production) ─
SIMULATION_ENABLED=false
SIMULATION_INTERVAL_SECONDS=5

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# ── CORS & Trusted Hosts ────────────────────────────────────
CORS_ORIGINS=["https://your-domain.com"]
ALLOWED_HOSTS=["your-domain.com", "www.your-domain.com"]

# ══════════════════════════════════════════════════════════════
# Database Seed Variables (for initial setup via seed_database.py)
# ══════════════════════════════════════════════════════════════
SEED_ORG_NAME=              # Your organization name
SEED_ORG_SLUG=              # URL-safe slug (e.g., "my-company")
SEED_ORG_DESCRIPTION=       # Optional description
SEED_ORG_TIER=enterprise
SEED_ORG_MAX_EQUIPMENT=100
SEED_ADMIN_EMAIL=           # Admin email address
SEED_ADMIN_PASSWORD=        # Admin password (min 10 characters)
SEED_ADMIN_NAME=            # Admin full name
SEED_ENGINEER_EMAIL=        # Optional: engineer email
SEED_ENGINEER_PASSWORD=     # Optional: engineer password (min 10 chars)
SEED_ENGINEER_NAME=         # Optional: engineer full name
