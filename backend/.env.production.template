# ============================================================
# Production Environment Configuration Template
# ============================================================
# Copy this file to .env.production and fill in ALL values.
# NEVER commit .env.production to version control!
#
# Generate a strong JWT secret:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=your-db-host.example.com
POSTGRES_PORT=5432
POSTGRES_DB=predictive_maintenance
POSTGRES_USER=pm_prod_user
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=your-redis-host.example.com
REDIS_PORT=6379
REDIS_DB=0

# ── JWT Tokens (CHANGE THESE!) ───────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_RANDOM_SECRET
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML Configuration ────────────────────────────────────────
ML_MODEL_DIR=./ml_models/saved_models
ML_DEFAULT_MODEL=xgboost
ML_PREDICTION_THRESHOLD=0.7

# ── Alerts ───────────────────────────────────────────────────
ALERT_HIGH_RISK_THRESHOLD=0.8
ALERT_MEDIUM_RISK_THRESHOLD=0.5
ALERT_EMAIL_ENABLED=true
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_USER=alerts@your-domain.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
ALERT_FROM_EMAIL=alerts@your-domain.com

# ── Simulation (DISABLE in production) ───────────────────────
SIMULATION_ENABLED=false

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_FILE=logs/app.log

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["https://your-frontend-domain.com"]
